---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { suitesEs } from "@/data/suites-es";
import { slugify } from "@/utils/slugify";
import SuiteGallery from "@/components/react/SuiteGallery";
import { getResponsiveImage } from "@/utils/responsive-images";
import { HOTEL_PROFILE, absoluteUrl } from "@/utils/seo";


export function getStaticPaths() {
  return suitesEs.map((suite) => ({
    params: { slug: slugify(suite.title) },
    props: { suite },
  }));
}

const { suite } = Astro.props as { suite: (typeof suitesEs)[number] };
const displayTitle = suite.displayTitle ?? suite.title;
const title = `${displayTitle} | El Ensueño`;
const description = suite.description;
const defaultBookingUrl =
  "https://be.synxis.com/?adult=1&arrive=2025-12-26&chain=22402&child=0&currency=USD&depart=2025-12-27&hotel=78821&level=hotel&locale=es-MX&productcurrency=USD&room=ENS&rooms=1&src=24C";
const bookingUrl = suite.bookingUrl ?? defaultBookingUrl;
const galleryImages = [
  suite.heroImage,
  ...suite.details.map((detail) => detail.image),
  ...suite.gallery,
];
const uniqueImages = Array.from(new Set(galleryImages));
const galleryImageMap = Object.fromEntries(
  await Promise.all(
    uniqueImages.map(async (path) => [
      path,
      await getResponsiveImage(path, {
        widths: [480, 768, 1024, 1366, 1600],
        sizes: "(min-width: 1024px) 66vw, 100vw",
        priority: path === suite.heroImage,
      }),
    ]),
  ),
);
const heroImage = galleryImageMap[suite.heroImage];
const slug = Astro.params.slug ?? slugify(suite.title);
const siteUrl = Astro.site;
const suiteUrl = absoluteUrl(`/es/suites/${slug}/`, siteUrl);
const homeUrl = absoluteUrl("/es/", siteUrl);
const roomImages = uniqueImages
  .slice(0, 8)
  .map((path) => absoluteUrl(galleryImageMap[path].src, siteUrl));
const guestCount = Number.parseInt(suite.guests.match(/\d+/)?.[0] ?? "2", 10);
const rateNumber = Number.parseInt(suite.rate.replace(/[^\d]/g, ""), 10);
const structuredData = [
  {
    "@type": "HotelRoom",
    "@id": `${suiteUrl}#room`,
    name: `Suite ${displayTitle}`,
    description,
    url: suiteUrl,
    inLanguage: "es-MX",
    image: roomImages,
    bed: suite.bed,
    occupancy: {
      "@type": "QuantitativeValue",
      value: guestCount,
      unitText: "huéspedes",
    },
    amenityFeature: suite.amenities.map((amenity) => ({
      "@type": "LocationFeatureSpecification",
      name: amenity,
      value: true,
    })),
    containedInPlace: {
      "@type": "LodgingBusiness",
      "@id": `${homeUrl}#organization`,
      name: HOTEL_PROFILE.name,
      url: homeUrl,
    },
    ...(Number.isFinite(rateNumber) && rateNumber > 0
      ? {
          offers: {
            "@type": "Offer",
            price: rateNumber,
            priceCurrency: "USD",
            availability: "https://schema.org/InStock",
            url: bookingUrl,
          },
        }
      : {}),
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Inicio",
        item: homeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Suites",
        item: `${homeUrl}#suites`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: displayTitle,
        item: suiteUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage={heroImage.src}
  preloadImages={[heroImage.src]}
  structuredData={structuredData}
  currentLang="es"
>
  <!-- Hero Section Full Width -->
  <section class="relative h-screen min-h-[600px]">
    <div class="absolute inset-0">
      <img
        src={heroImage.src}
        alt={displayTitle}
        class="h-full w-full object-cover"
        loading={heroImage.loading ?? "eager"}
        decoding={heroImage.decoding ?? "async"}
        fetchpriority={heroImage.fetchPriority ?? "high"}
        srcset={heroImage.srcSet}
        sizes={heroImage.sizes}
        width={heroImage.width}
        height={heroImage.height}
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60"></div>
    </div>
    <div class="relative flex h-full items-end">
      <div class="w-full pb-16 pt-32">
        <div class="max-w-6xl mx-auto px-6 sm:px-10">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-serif text-white">{displayTitle}</h1>
          <p class="mt-4 max-w-2xl text-lg text-white/90 font-bold">{suite.tagline}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Room Overview Section -->
  <section class="py-16 bg-white">
    <div class="w-full px-6 sm:px-10">
      <div class="grid lg:grid-cols-[2fr,1fr] gap-12">
        {/* Photo à gauche - 67% de l'espace */}
        <div class="lg:sticky lg:top-24 self-start">
          <SuiteGallery 
            client:visible
            images={uniqueImages}
            imageMap={galleryImageMap}
            title={displayTitle}
            lang="es"
          />
        </div>

        {/* Contenu à droite - 33% de l'espace */}
        <div class="max-w-xl">
          <h2 class="text-3xl sm:text-4xl font-serif text-[#8B9F7E] mb-2">{displayTitle}</h2>
          
          {/* Détails de la suite */}
          <div class="mb-8 space-y-1 text-ink/80">
            <p class="text-base font-medium">{suite.size}</p>
            <p class="text-sm">{suite.view}</p>
            <p class="text-sm">{suite.guests}</p>
            <p class="text-sm">{suite.bed}</p>
          </div>

          {/* Description principale */}
          <p class="text-base text-ink/70 leading-relaxed mb-10">{suite.description}</p>
          
          {/* Amenities */}
          <div class="mb-10">
            <h3 class="text-2xl font-serif text-[#4A90C4] mb-6 pb-2 border-b-2 border-[#4A90C4]">Amenidades</h3>
            <ul class="space-y-3">
              {suite.amenities.map((amenity) => (
                <li class="text-sm text-ink/80">{amenity}</li>
              ))}
            </ul>
          </div>

          {/* Bouton Book Now */}
          <div class="mt-12">
            <a
              href={bookingUrl}
              class="inline-block bg-[#FEAB5B] hover:bg-[#e89e53] text-ink font-semibold px-12 py-4 rounded transition-all"
            >
              RESERVAR
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
